RewriteEngine On

# Serve favicon from its folder when browsers request /favicon.ico directly
RewriteRule ^favicon\.ico$ /favicon/favicon.ico [L]

# Enforce HTTPS (handle proxy headers without redirect loops)
RewriteCond %{HTTPS} !=on
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Redirect .html requests to the clean URL
# Redirect index.html → /
RewriteRule ^index\.html$ / [R=301,L]

# Redirect .html requests to clean URLs (except index)
RewriteCond %{THE_REQUEST} \s/([^.]+)\.html [NC]
RewriteCond %1 !=index
RewriteRule ^ /%1 [R=301,L]

# Serve .html file if it exists
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

# Remove trailing slashes from URLs
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)/$ /$1 [R=301,L]

# ------------------------------------------
# Disable directory listing
Options -Indexes

# Default page
DirectoryIndex index.html

# ------------------------------------------
# Error Pages
ErrorDocument 403 assets/error/403.html
ErrorDocument 404 assets/error/404.html
ErrorDocument 301 assets/error/301.html

# ------------------------------------------
# Security Headers
# ------------------------------------------
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), camera=(), microphone=()"
</IfModule>

# Block access to hidden files
<FilesMatch "^\.">
  Require all denied
</FilesMatch>

<FilesMatch "(\.env|\.git|\.htaccess|\.htpasswd|Dockerfile|fly\.toml|\.DS_Store|notes\.txt)$">
  Require all denied
</FilesMatch>

<LimitExcept GET HEAD>
  Require all denied
</LimitExcept>

AddDefaultCharset UTF-8

SetEnvIfNoCase User-Agent "MJ12bot|AhrefsBot|SemrushBot|Baiduspider" bad_bot
Deny from env=bad_bot

# Robots/AI directives
<IfModule mod_headers.c>
  # Default for all HTML: allow indexing but opt out of AI training
  <FilesMatch "\.html$">
    Header set X-Robots-Tag "index, follow, noai, noimageai"
  </FilesMatch>

  # Error pages: keep them out of indexes
  <FilesMatch "^(assets/error/)?(403|404|301)\.html$">
    Header set X-Robots-Tag "noindex, nofollow, noai, noimageai"
  </FilesMatch>
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 1 hour"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/ttf "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
</IfModule>

# Explicit cache-control (mirrors Expires above)
<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|woff2?|ttf|otf|svg|png|jpe?g|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=3600"
  </FilesMatch>
</IfModule>
